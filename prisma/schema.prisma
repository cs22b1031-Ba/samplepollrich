generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuoteRequest {
  id           String   @id @default(cuid())
  fullName     String
  companyName  String
  companyEmail String
  phoneNumber  String
  message      String
  createdAt    DateTime @default(now())
}
